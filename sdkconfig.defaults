CONFIG_FREERTOS_ENABLE_BACKWARD_COMPATIBILITY=y

CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_OFFSET=0x8000
CONFIG_PARTITION_TABLE_MD5=y

# OTA anti-brick: a freshly OTA-flashed app boots in PENDING_VERIFY and must
# confirm itself (esp_ota_mark_app_valid_cancel_rollback) or the bootloader
# rolls back to the previous slot on the next boot. wifi_manager confirms on the
# first STA GOT_IP. No-op on the 8 MB factory layout (no OTA partitions).
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

CONFIG_IDF_TARGET="esp32s3"

CONFIG_ESP32_S3_ATLASCUBE_BOARD=y

# Display + touch driver + flash size selection lives in main/include/defines.h.
# Top-level CMakeLists.txt parses it and generates build/sdkconfig.variant
# (CONFIG_DISPLAY_*, CONFIG_TOUCH_*, CONFIG_ESPTOOLPY_FLASHSIZE_*, CONFIG_PARTITION_TABLE_*FILENAME).

CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# Allows placing the .bss segment in PSRAM (via EXT_RAM_BSS_ATTR).
# Without this, the attribute is a no-op and large static arrays stay in internal RAM.
CONFIG_SPIRAM_ALLOW_BSS_SEG_EXTERNAL_MEMORY=y


# WARNING: MBEDTLS_DYNAMIC_BUFFER + RENEGOTIATION = broken HTTPS
# Eurozet CDN requires TLS renegotiation after connection is established.
# Dynamic buffer cannot expand in time → PEER_CLOSE_NOTIFY (-0x7100).
# Solution: use EXTERNAL_MEM_ALLOC instead of DYNAMIC_BUFFER.
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=16384
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=4096
CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC=y
# Threshold: allocations below this value stay in internal RAM, larger ones → PSRAM.
# Lowered 8192 → 4096 — internal RAM baseline is ~7-8KB largest block, so with
# 8192 too many small mbedTLS/lwIP allocations stayed in internal RAM,
# fragmenting it and breaking TLS handshake.
# Lowered 4096 → 2048 — while the radio HTTPS stream runs, the internal largest
# free block fell to ~2.3KB, too small for httpd to allocate a TCP TX pbuf
# (~MSS 1440 B): serving a web asset failed with errno 11 / EWOULDBLOCK. Pushing
# more sub-4KB mbedTLS/lwIP allocations to PSRAM frees the internal heap so the
# pbuf fits and the web UI stays usable mid-stream.
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=2048

# Hardware crypto re-enabled 2026-07-03: software AES-GCM (gcm_mult GHASH) on the
# TLS record path was pegging CPU0 during HLS/HTTPS playback → IDLE0 task_wdt +
# audible stutter. HW AES pulls in HW GCM (S3 AES peripheral does GHASH), and
# HW SHA/MPI accelerate the per-segment TLS handshakes HLS keeps reopening.
# The old "failed allocation during renegotiation" reason no longer holds after the
# 2026-06-15 RAM recovery (INT largest free ~31KB mid-stream now).
CONFIG_MBEDTLS_HARDWARE_AES=y
CONFIG_MBEDTLS_HARDWARE_SHA=y
CONFIG_MBEDTLS_HARDWARE_MPI=y

# WARNING: DYNAMIC_BUFFER + renegotiation = broken HTTPS (Eurozet CDN)
# If HW AES regresses on a renegotiating CDN under low internal RAM, revert these to n.


CONFIG_HTTPD_WS_SUPPORT=y
CONFIG_FREERTOS_USE_STATS_FORMATTING_FUNCTIONS=y
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=y

# CONFIG_LV_FONT_MONTSERRAT_12=y
# CONFIG_LV_FONT_MONTSERRAT_14=y
# CONFIG_LV_FONT_MONTSERRAT_18=y
# CONFIG_LV_FONT_MONTSERRAT_28=y
CONFIG_LV_FONT_MONTSERRAT_48=y

# On-screen FPS + CPU% overlay (bottom-right) for perf/stability testing.
# PERF_MONITOR requires SYSMON, which requires OBSERVER. Kept in Kconfig (not a
# -D on the lvgl lib) because these change lv_global_t layout and must be seen
# identically by every translation unit.
CONFIG_LV_USE_OBSERVER=y
CONFIG_LV_USE_SYSMON=y
CONFIG_LV_USE_PERF_MONITOR=y

CONFIG_LWIP_MAX_SOCKETS=16

# Segmented HLS (.m3u8) radio opens a fresh TLS connection per .ts segment and
# per playlist refresh — without connection reuse this is ~0.5 conn/s. With the
# default 60 s TIME_WAIT (TCP_MSL) the closed sockets pile up past the 16-socket
# pool and new connects start timing out. Shortening TIME_WAIT to 10 s frees
# them ~6x faster so the pool never exhausts.
CONFIG_LWIP_TCP_MSL=10000

# TCP receive buffer and window — default 5760 B is too small for 256 kbps
# audio streams. A small window forces frequent ACKs and limits throughput
# due to the bandwidth-delay product, which results in stuttering at playback start
# (TCP slow-start cannot fill the esp-adf ring buffer fast enough).
# 32 KB ≈ 1 second at 256 kbps; leaves margin for network jitter.
CONFIG_LWIP_TCP_WND_DEFAULT=32768
CONFIG_LWIP_TCP_RCV_BUF_DEFAULT=32768
CONFIG_LWIP_TCP_RECVMBOX_SIZE=32

# WiFi internal-RAM tuning. These trim WiFi's internal DMA-RAM footprint and
# were previously only in the (gitignored) sdkconfig — a clean rebuild reset them
# to the larger IDF defaults and the device ran out of internal RAM at boot
# (fopen → lock_init_generic → abort). Kept here so they survive clean builds.
#  - fewer static RX buffers, dynamic (on-demand) TX buffers instead of 16 static
#  - smaller block-ack RX window, no out-of-sequence pbuf queue
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=10
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER=y
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=32
CONFIG_ESP_WIFI_RX_BA_WIN=6
CONFIG_LWIP_TCP_OOSEQ_MAX_PBUFS=4

# NOTE: do NOT enable CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP. It forces WiFi into
# the *static* TX-buffer model (16 DMA-capable TX buffers + 32 tx-cache, all in
# internal RAM), which consumed MORE internal DRAM than it freed: idle largest
# free block dropped 14 KB → 3.5 KB and the audio dsp/i2s tasks failed to create
# (audio_thread_create failed). DYNAMIC_TX_BUFFER above is the smaller-footprint
# choice; the page-serve-under-stream RAM pressure must be solved elsewhere.

CONFIG_LV_USE_FONT_PLACEHOLDER=n

# FATFS long file names on the SD card. The IDF default (LFN_NONE) restricts SD
# filenames to 8.3, so anything with a >3-char extension (.html, .json) or >8-char
# base fails fopen() — e.g. the SPIFFS↔SD backup manager and slides.json. HEAP
# variant keeps the LFN work buffer off the (tight) internal DRAM and off the
# audio/http task stacks; ~(MAX_LFN+1)*2 B malloc'd per directory op, freed after.
CONFIG_FATFS_LFN_HEAP=y
CONFIG_FATFS_MAX_LFN=255

# Core 1 is the compute core by design (aac/rsp/dsp decode tasks + LVGL, all
# prio 5): a 48 kHz stream (e.g. HLS video audio) needs a real 48000->44100
# resample and legitimately saturates the core for >5 s, starving IDLE1 and
# spamming task_wdt warnings. That is a working state, not a hang, so IDLE1
# leaves the watchdog; IDLE0 (Wi-Fi/lwIP/system core) stays supervised.
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU1=n

# CONFIG_LOG_DEFAULT_LEVEL_DEBUG=y